# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.java text diff=java
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp
*.go text diff=golang
*.proto text
*.sql text

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Configuration files
*.yml text
*.yaml text
*.json text
*.xml text
*.properties text
*.conf text
*.config text

# Documentation
*.md text
*.txt text
*.adoc text

# Binary files
*.jar binary
*.war binary
*.ear binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
*.a binary
*.o binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Exclude files from exporting
.gitattributes export-ignore
.gitignore export-ignore
.editorconfig export-ignore
